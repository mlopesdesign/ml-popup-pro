{
	"name": "mlopesdesign/ml-popup-pro",
	"description": "ML Popup Pro – premium WordPress popup manager.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"require": {
		"php": ">=8.1",
		"ext-json": "*"
	},
	"require-dev": {
		"phpunit/phpunit": "^9.6",
		"yoast/phpunit-polyfills": "^2.0"
	},
	"autoload": {
		"files": [ "tests/stubs/wp-functions.php" ]
	},
	"scripts": {
		"test": "phpunit --colors=always",
		"coverage": "phpunit --colors=always --coverage-text",
		"php:lint": "find includes -name '*.php' -print0 | xargs -0 -n1 php -l",
		"i18n:pot": "find includes -name '*.php' | xargs xgettext --language=PHP --add-comments --sort-output --from-code=UTF-8 -o languages/ml-popup-pro.pot"
	},
	"config": {
		"preferred-install": "dist",
		"sort-packages": true
	},
	"minimum-stability": "stable"
}